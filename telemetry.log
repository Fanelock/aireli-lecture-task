itorChangeEvent","eventTime":1773755666795,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":13,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"supreme-space-invention-97jpwpv5w65437w66","eventName":"DocumentChangeEvent","eventTime":1773755673524,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":13,"operation":"delete","value":"","rangeOffset":"224","rangeLength":"1131","rangestart_line":"5","rangestart_character":"0","rangeend_line":"57","rangeend_character":"10"},{"codespaceName":"supreme-space-invention-97jpwpv5w65437w66","eventName":"DocumentChangeEvent","eventTime":1773755673945,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":13,"operation":"add","value":"const registerUser = async (input: PlatformUserCreateInput): Promise<Pick<PlatformUser, \"id\"> | undefined | null> => {\n  try {\n    const { data } = await axios.post('http://127.0.0.1:3000', {\n      email: input.email,\n      password: input.password,\n    });\n    return data;\n  } catch (error: any) {\n    console.error(error);\n    return null;\n  }\n};\n\nconst loginUser = async (input: PlatformUserCreateInput) => {\n  // ToDo: Implement the loginUser function (someone else is working on it)\n  const user = {id: null} // replace this line\n\n\n  // The following lines can be left unchanged because the output is expected to be a JWT token and an expiresAt value\n  const accessToken = jwt.sign({ id: user?.id }, process.env.JWT_SECRET || \"no_key_set\" as string, { expiresIn: '1h' });\n  const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString(); // 3600 seconds = 1 hour\n  return { accessToken, expiresAt };\n};\n\nconst getUser = async (accessToken: string): Promise<PlatformUser | undefined | null> => {\n  try {\n    if(accessToken != \"\") {\n      const { data } = await axios.get('http://localhost:3001/me', {\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n        },\n      });\n\n      return data.user;\n    } else {\n      return null\n    }\n  } catch (error) {\n    console.error(error);\n    \n    return null;\n  }\n};\n\nexport default {\n  registerUser,\n  loginUser,\n  getUser","rangeOffset":"224","rangeLength":"0","rangestart_line":"5","rangestart_character":"0","rangeend_line":"5","rangeend_character":"0"},{"codespaceName":"supreme-space-invention-97jpwpv5w65437w66","eventName":"DocumentChangeEvent","eventTime":1773755678864,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":13,"operation":"add","value":"/","rangeOffset":"411","rangeLength":"0","rangestart_line":"7","rangestart_character":"60","rangeend_line":"7","rangeend_character":"60"},{"codespaceName":"supreme-space-invention-97jpwpv5w65437w66","eventName":"DocumentChangeEvent","eventTime":1773755678974,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":13,"operation":"add","value":"r","rangeOffset":"412","rangeLength":"0","rangestart_line":"7","rangestart_character":"61","rangeend_line":