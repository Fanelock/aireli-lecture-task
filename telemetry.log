ention-97jpwpv5w65437w66","eventName":"DocumentChangeEvent","eventTime":1773754239957,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":13,"operation":"add","value":"const users: PlatformUser[] = [];\n\nconst registerUser = async (\n  input: PlatformUserCreateInput\n): Promise<Pick<PlatformUser, \"id\"> | null> => {\n  const user: PlatformUser = {\n    id: String(users.length + 1),\n    email: input.email,\n  };\n\n  users.push(user);\n\n  return { id: user.id };\n};\n\nconst loginUser = async (input: PlatformUserCreateInput) => {\n  const user = users.find(u => u.email === input.email);\n\n  if (!user) {\n    throw new Error(\"Invalid credentials\");\n  }\n\n  const accessToken = jwt.sign(\n    { id: user.id },\n    process.env.JWT_SECRET || \"no_key_set\",\n    { expiresIn: '1h' }\n  );\n\n  const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString();\n\n  return { accessToken, expiresAt };\n};\n\nconst getUser = async (accessToken: string): Promise<PlatformUser | null> => {\n  try {\n    if (!accessToken) return null;\n\n    const decoded: any = jwt.verify(\n      accessToken,\n      process.env.JWT_SECRET || \"no_key_set\"\n    );\n\n    return users.find(u => u.id === decoded.id) || null;\n  } catch (error) {\n    console.error(error);\n    return null;\n  }\n};\n\nexport default {\n  registerUser,\n  loginUser,\n  getUser,","rangeOffset":"224","rangeLength":"0","rangestart_line":"5","rangestart_character":"0","rangeend_line":"5","rangeend_character":"0"},{"codespaceName":"supreme-space-invention-97jpwpv5w65437w66","eventName":"WindowStateChangeEvent","eventTime":1773754243940,"sessionId":"df1fba39-ff2a-48ea-95cd-849c2314b9851773749833934","machineId":"7f02458e79ceab11bae5999fa5228b360fd4566409c127eb57c3fe9fb275f5b5","documentUri":"","documentId":0,"operation":"